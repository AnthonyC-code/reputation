# Copy to .env and fill in real values. Every variable used by the app MUST
# appear here with a comment and a fake value (AGENTS.md §4).

# --- passportd ---
# HTTP listen address for the API server
API_ADDR=:8080
# Postgres connection string (matches docker-compose: host port 5433)
DATABASE_URL=postgres://passport:passport@localhost:5433/passport?sslmode=disable
# Environment name: dev | test | prod (dev auto-runs migrations on serve)
APP_ENV=dev

# --- integration tests ---
# When set, Go integration tests run against this database; unset = skipped
#TEST_DATABASE_URL=postgres://passport:passport@localhost:5433/passport_test?sslmode=disable

# --- web ---
# Base URL the Next.js app uses to reach the Go API
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- coming in later phases (placeholders, not yet read) ---
# Ed25519 signing key, base64 (Phase 3; prod: AWS Secrets Manager)
#ATTEST_SIGNING_KEY=
# AES-256 key for OAuth-token encryption at rest, base64 (Phase 2)
#TOKEN_ENCRYPTION_KEY=
# Clerk (Phase 1)
#CLERK_SECRET_KEY=sk_test_fake
#NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_fake
# Shopify partner app (Phase 2)
#SHOPIFY_API_KEY=fake
#SHOPIFY_API_SECRET=fake
# Public HTTPS tunnel for OAuth callbacks in dev (cloudflared)
#PUBLIC_BASE_URL=https://example.trycloudflare.com
